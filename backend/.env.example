# ============================================================================
# DATABASE — Supabase PostgreSQL
# ============================================================================
# Supabase Dashboard → Project Settings → Database → Connection String
#
# DATABASE_URL  → "Session mode" pooled connection (port 6543)
#                  Used at runtime by Prisma Client for all queries.
#
# DIRECT_URL    → "Direct connection" (port 5432)
#                  Used by Prisma CLI for migrations & db push only.
#                  This bypasses PgBouncer so that DDL statements work.
#
# Replace [PROJECT_REF] with your project reference (e.g. abcdefghijklmnop)
# Replace [PASSWORD]     with the database password you set when creating the project
# Replace [REGION]       with your project region (e.g. ap-south-1)
# ============================================================================
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ============================================================================
# AUTHENTICATION — JWT Tokens
# ============================================================================
# JWT_SECRET           → Signs access tokens. Use a strong random string (32+ chars).
# JWT_EXPIRES_IN       → Access token lifetime (e.g. "15m", "1h", "7d").
# JWT_REFRESH_SECRET   → Signs refresh tokens. Must be different from JWT_SECRET.
# JWT_REFRESH_EXPIRES_IN → Refresh token lifetime (e.g. "30d").
# ============================================================================
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="your-refresh-token-secret-change-this"
JWT_REFRESH_EXPIRES_IN="30d"

# ============================================================================
# SERVER
# ============================================================================
# PORT      → HTTP port the Express server listens on.
# NODE_ENV  → "development" | "production" | "test"
# ============================================================================
PORT=5000
NODE_ENV="development"

# ============================================================================
# CORS
# ============================================================================
# FRONTEND_URL     → Primary frontend origin allowed by CORS.
# MOBILE_APP_URL   → Expo dev server origin (e.g. exp://192.168.x.x:8081).
#                     Native mobile apps send no Origin header and are already
#                     allowed by the !origin bypass in the CORS middleware.
# ALLOWED_ORIGINS  → (Production) Comma-separated list of allowed origins.
# ============================================================================
FRONTEND_URL="http://localhost:5173"
MOBILE_APP_URL="exp://192.168.x.x:8081"
RENDER_APP_URL="https://parkeasy-backend.onrender.com"
# ALLOWED_ORIGINS="https://yourdomain.com,https://www.yourdomain.com"

# ============================================================================
# BUSINESS LOGIC
# ============================================================================
# RESERVATION_TIMEOUT_MINUTES → How long a slot is held before auto-release.
# ============================================================================
RESERVATION_TIMEOUT_MINUTES=5

# ============================================================================
# THIRD-PARTY SERVICES (optional)
# ============================================================================
# GOOGLE_MAPS_API_KEY   → Google Maps Platform key for distance calculations.
#                          Get one at https://console.cloud.google.com/
#
# RAZORPAY_KEY_ID       → Razorpay API key ID (starts with rzp_test_ or rzp_live_).
# RAZORPAY_KEY_SECRET   → Razorpay API key secret.
#                          Get credentials at https://dashboard.razorpay.com/
# ============================================================================
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"
RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
