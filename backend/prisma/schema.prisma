generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String            @id @default(uuid())
  email              String            @unique
  password_hash      String
  full_name          String?
  role               String            @default("CUSTOMER")
  balance            Decimal           @default(0) @db.Decimal(12, 2)
  push_token         String?
  created_at         DateTime          @default(now())
  updated_at         DateTime          @updatedAt
  phone_number       String?           @unique
  favorites          Favorite[]
  monthly_passes     MonthlyPass[]
  parking_facilities ParkingFacility[]
  refresh_tokens     RefreshToken[]
  settlements        Settlement[]
  tickets            Ticket[]
  vehicles           Vehicle[]
  withdrawals        Withdrawal[]      @relation("UserWithdrawals")

  @@map("users")
}

model Withdrawal {
  id                  String   @id @default(uuid())
  provider_id         String   @map("user_id")
  amount              Decimal  @db.Decimal(12, 2)
  status              String   @default("PENDING")
  payout_id           String?
  error_msg           String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  currency            String   @default("INR")
  destination_account String?
  idempotency_key     String?  @unique
  payout_details      String?
  payout_method       String   @default("UPI")
  remarks             String?
  provider            User     @relation("UserWithdrawals", fields: [provider_id], references: [id])

  @@index([provider_id])
  @@index([status])
  @@map("withdrawals")
}

model Settlement {
  id           String   @id @default(uuid())
  user_id      String
  amount       Decimal  @db.Decimal(12, 2)
  ticket_count Int
  status       String   @default("PENDING")
  period_start DateTime
  period_end   DateTime
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  user         User     @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("settlements")
}

model PlatformTransaction {
  id           String   @id @default(uuid())
  ticket_id    String?  @unique
  amount       Decimal  @db.Decimal(12, 2)
  platform_fee Decimal  @db.Decimal(12, 2)
  net_amount   Decimal  @db.Decimal(12, 2)
  type         String
  created_at   DateTime @default(now())

  @@map("platform_transactions")
}

model RefreshToken {
  id         String   @id @default(uuid())
  token_hash String   @unique
  user_id    String
  expires_at DateTime
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("refresh_tokens")
}

model ParkingFacility {
  id              String        @id @default(uuid())
  provider_id     String
  name            String
  address         String
  city            String
  latitude        Decimal?
  longitude       Decimal?
  total_floors    Int           @default(1)
  operating_hours String?
  is_active       Boolean       @default(true)
  image_url       String?
  contact_number  String?
  description     String?
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt
  favorites       Favorite[]
  floors          Floor[]
  monthly_passes  MonthlyPass[]
  provider        User          @relation(fields: [provider_id], references: [id])
  pricing_rules   PricingRule[]
  tickets         Ticket[]

  @@map("parking_facilities")
}

model Floor {
  id            String          @id @default(uuid())
  facility_id   String
  floor_number  Int
  floor_name    String?
  facility      ParkingFacility @relation(fields: [facility_id], references: [id], onDelete: Cascade)
  parking_slots ParkingSlot[]

  @@unique([facility_id, floor_number])
  @@map("floors")
}

model ParkingSlot {
  id                 String    @id @default(uuid())
  floor_id           String
  slot_number        String
  vehicle_type       String
  status             String    @default("FREE")
  area_sqft          Decimal?
  is_active          Boolean   @default(true)
  reservation_expiry DateTime?
  floor              Floor     @relation(fields: [floor_id], references: [id], onDelete: Cascade)
  tickets            Ticket[]

  @@unique([floor_id, slot_number])
  @@index([floor_id, status])
  @@map("parking_slots")
}

model Ticket {
  id             String          @id @default(uuid())
  customer_id    String
  facility_id    String
  slot_id        String?
  vehicle_number String
  vehicle_type   String
  entry_time     DateTime        @default(now())
  exit_time      DateTime?
  base_fee       Decimal?        @db.Decimal(12, 2)
  extra_charges  Decimal?        @db.Decimal(12, 2)
  total_fee      Decimal?        @db.Decimal(12, 2)
  status         String          @default("ACTIVE")
  payment_status String?         @default("PENDING")
  payment_method String?
  payment_id     String?
  qr_code        String?
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt
  booking_type   String          @default("ONLINE")
  customer       User            @relation(fields: [customer_id], references: [id])
  facility       ParkingFacility @relation(fields: [facility_id], references: [id])
  slot           ParkingSlot?    @relation(fields: [slot_id], references: [id])

  @@index([slot_id, entry_time, exit_time])
  @@map("tickets")
}

model MonthlyPass {
  id             String          @id @default(uuid())
  customer_id    String
  facility_id    String
  vehicle_type   String
  start_date     DateTime
  end_date       DateTime
  price          Decimal         @db.Decimal(12, 2)
  status         String          @default("ACTIVE")
  payment_id     String?
  payment_status String?         @default("PAID")
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt
  customer       User            @relation(fields: [customer_id], references: [id])
  facility       ParkingFacility @relation(fields: [facility_id], references: [id])

  @@map("monthly_passes")
}

model PricingRule {
  id                 String          @id @default(uuid())
  facility_id        String
  vehicle_type       String
  hourly_rate        Decimal         @db.Decimal(12, 2)
  daily_max          Decimal?        @db.Decimal(12, 2)
  monthly_pass_price Decimal?        @db.Decimal(12, 2)
  facility           ParkingFacility @relation(fields: [facility_id], references: [id], onDelete: Cascade)

  @@unique([facility_id, vehicle_type])
  @@map("pricing_rules")
}

model Vehicle {
  id             String   @id @default(uuid())
  user_id        String
  vehicle_number String
  vehicle_type   String
  nickname       String?
  created_at     DateTime @default(now())
  user           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("vehicles")
}

model Favorite {
  id          String          @id @default(uuid())
  user_id     String
  facility_id String
  created_at  DateTime        @default(now())
  facility    ParkingFacility @relation(fields: [facility_id], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, facility_id])
  @@map("favorites")
}
