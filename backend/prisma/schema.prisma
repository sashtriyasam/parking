// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String        @id @default(uuid())
  email         String        @unique
  password_hash String
  full_name     String?
  role          String        @default("CUSTOMER")
  balance       Decimal       @default(0) @db.Decimal(12, 2)
  push_token    String?
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  parking_facilities ParkingFacility[]
  tickets            Ticket[]
  monthly_passes     MonthlyPass[]
  vehicles           Vehicle[]
  favorites          Favorite[]
  refresh_tokens     RefreshToken[]
  withdrawals        Withdrawal[] @relation("UserWithdrawals")
  settlements        Settlement[]
  @@map("users")
}

model Withdrawal {
  id                  String   @id @default(uuid())
  provider_id         String   @map("user_id") // Keep DB column as user_id but map to provider_id in Prisma
  provider            User     @relation("UserWithdrawals", fields: [provider_id], references: [id], onDelete: Restrict)
  amount              Decimal  @db.Decimal(12, 2)
  currency            String   @default("INR")
  status              String   @default("PENDING") // PENDING, APPROVED, COMPLETED, REJECTED
  payout_method       String   @default("UPI")     // UPI, BANK
  payout_details      String?  @db.Text            // Encrypted or partial bank/UPI details
  destination_account String?                      // Optional specific destination account reference
  payout_id           String?  // External payment Gateway ID (e.g. Razorpay Fund Account ID)
  idempotency_key     String?  @unique
  remarks             String?  @db.Text
  error_msg           String?  @db.Text
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@index([provider_id])
  @@index([status])
  @@map("withdrawals")
}

model Settlement {
  id           String   @id @default(uuid())
  user_id      String
  user         User     @relation(fields: [user_id], references: [id], onDelete: Restrict)
  amount       Decimal  @db.Decimal(12, 2)
  ticket_count Int
  status       String   @default("PENDING") // PENDING, SETTLED
  period_start DateTime
  period_end   DateTime
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([user_id])
  @@map("settlements")
}

model PlatformTransaction {
  id            String   @id @default(uuid())
  ticket_id     String?  @unique
  amount        Decimal  @db.Decimal(12, 2) // Total transaction amount
  platform_fee  Decimal  @db.Decimal(12, 2) // Deducted fee
  net_amount    Decimal  @db.Decimal(12, 2) // Net earnings for provider
  type          String   // TRANSACTION, WITHDRAWAL, REFUND
  created_at    DateTime @default(now())

  @@map("platform_transactions")
}
model RefreshToken {
  id         String   @id @default(uuid())
  token_hash String   @unique
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  expires_at DateTime
  created_at DateTime @default(now())
  @@index([user_id])
  @@map("refresh_tokens")
}

model ParkingFacility {
  id              String        @id @default(uuid())
  provider_id     String
  provider        User          @relation(fields: [provider_id], references: [id])
  name            String
  address         String
  city            String
  latitude        Decimal?
  longitude       Decimal?
  total_floors    Int           @default(1)
  operating_hours String?       @db.Text
  is_active       Boolean       @default(true)
  image_url       String?       @db.Text
  contact_number  String?
  description     String?       @db.Text
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt
  floors          Floor[]
  pricing_rules   PricingRule[]
  monthly_passes  MonthlyPass[]
  tickets         Ticket[]
  favorites       Favorite[]
  @@map("parking_facilities")
}

model Floor {
  id           String          @id @default(uuid())
  facility_id  String
  facility     ParkingFacility @relation(fields: [facility_id], references: [id], onDelete: Cascade)
  floor_number Int
  floor_name   String?
  parking_slots ParkingSlot[]
  @@unique([facility_id, floor_number])
  @@map("floors")
}

model ParkingSlot {
  id           String      @id @default(uuid())
  floor_id     String
  floor        Floor       @relation(fields: [floor_id], references: [id], onDelete: Cascade)
  slot_number  String
  vehicle_type String
  status       String      @default("FREE")
  area_sqft    Decimal?
  is_active    Boolean     @default(true)
  reservation_expiry DateTime?
  tickets Ticket[]
  @@unique([floor_id, slot_number])
  @@index([floor_id, status])
  @@map("parking_slots")
}

model Ticket {
  id             String          @id @default(uuid())
  customer_id    String
  customer       User            @relation(fields: [customer_id], references: [id], onDelete: Restrict)
  facility_id    String
  facility       ParkingFacility @relation(fields: [facility_id], references: [id])
  slot_id        String?
  slot           ParkingSlot?     @relation(fields: [slot_id], references: [id], onDelete: SetNull)
  vehicle_number String
  vehicle_type   String
  entry_time     DateTime        @default(now())
  exit_time      DateTime?
  base_fee       Decimal?        @db.Decimal(12, 2)
  extra_charges  Decimal?        @db.Decimal(12, 2)
  total_fee      Decimal?        @db.Decimal(12, 2)
  status         String          @default("ACTIVE")
  payment_status String?         @default("PENDING")
  payment_method String?
  payment_id     String?
  qr_code        String?         @db.Text
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt
  @@map("tickets")
}

model MonthlyPass {
  id             String          @id @default(uuid())
  customer_id    String
  customer       User            @relation(fields: [customer_id], references: [id])
  facility_id    String
  facility       ParkingFacility @relation(fields: [facility_id], references: [id])
  vehicle_type   String
  start_date     DateTime
  end_date       DateTime
  price          Decimal         @db.Decimal(12, 2)
  status         String          @default("ACTIVE")
  payment_id     String?
  payment_status String?         @default("PAID")
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt
  @@map("monthly_passes")
}

model PricingRule {
  id                 String          @id @default(uuid())
  facility_id        String
  facility           ParkingFacility @relation(fields: [facility_id], references: [id], onDelete: Cascade)
  vehicle_type       String
  hourly_rate        Decimal         @db.Decimal(12, 2)
  daily_max          Decimal?        @db.Decimal(12, 2)
  monthly_pass_price Decimal?        @db.Decimal(12, 2)
  @@unique([facility_id, vehicle_type])
  @@map("pricing_rules")
}

model Vehicle {
  id             String      @id @default(uuid())
  user_id        String
  user           User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  vehicle_number String
  vehicle_type   String
  nickname       String?
  created_at     DateTime    @default(now())
  @@map("vehicles")
}

model Favorite {
  id          String          @id @default(uuid())
  user_id     String
  user        User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  facility_id String
  facility    ParkingFacility @relation(fields: [facility_id], references: [id], onDelete: Cascade)
  created_at  DateTime        @default(now())
  @@unique([user_id, facility_id])
  @@map("favorites")
}
